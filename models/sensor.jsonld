{
  "@context": {
    "@vocab":     "https://schema.org/",
    "sosa":       "http://www.w3.org/ns/sosa/",
    "ssn":        "http://www.w3.org/ns/ssn/",
    "ssn-system": "http://www.w3.org/ns/ssn/systems/",
    "xsd":        "http://www.w3.org/2001/XMLSchema#",
    "pipeline":   "https://github.com/manosmax/Smart-Waste-Bin/blob/main/docs/Ontology.md#"
  },

  "@graph": [
    {
      "@id":   "urn:dev:team08:pir-01",
      "@type": "sosa:Sensor",

      "name":        "HC-SR501 PIR Motion Sensor — Bin 01",
      "description": "HC-SR501 passive infrared motion sensor. Detects motion by sensing differential changes in infrared radiation.",
      "model":       "HC-SR501",

      "sosa:observes": {
        "@type":       "sosa:ObservableProperty",
        "@id":         "urn:prop:team08:motion",
        "name":        "Motion",
        "description": "Instantaneous motion (temperature > ambient) within the sensor field of view."
      },

      "ssn:hasProperty": [
        {
          "@type":              "ssn-system:MeasurementRange",
          "name":               "Detection Range",
          "pipeline:minValueM": { "@value": 0.5, "@type": "xsd:float" },
          "pipeline:maxValueM": { "@value": 7.0, "@type": "xsd:float" }
        },
        {
          "@type":                      "ssn:Property",
          "name":                       "Detection Angle",
          "pipeline:detectionAngleDeg": { "@value": 120, "@type": "xsd:integer" }
        },
        {
          "@type":                "ssn-system:SystemCapability",
          "name":                 "Supply Voltage Range",
          "pipeline:minVoltageV": { "@value": 4.5,  "@type": "xsd:float" },
          "pipeline:maxVoltageV": { "@value": 20.0, "@type": "xsd:float" }
        },
        {
          "@type":                   "ssn-system:SystemCapability",
          "name":                    "Output Signal Voltage HIGH",
          "pipeline:outputVoltageV": { "@value": 3.3, "@type": "xsd:float" }
        }
      ],

      "pipeline:gpioPin":        { "@type": "ssn:Property", "name": "GPIO Pin",        "schema:value": { "@value": 17,  "@type": "xsd:integer" } },
      "pipeline:physicalPin":    { "@type": "ssn:Property", "name": "Physical Pin",    "schema:value": { "@value": 11,  "@type": "xsd:integer" } },
      "pipeline:sampleIntervalS":{ "@type": "ssn:Property", "name": "Sample Interval", "schema:value": { "@value": 0.1, "@type": "xsd:float"   } },
      "pipeline:cooldownS":      { "@type": "ssn:Property", "name": "Cooldown",        "schema:value": { "@value": 5.0, "@type": "xsd:float"   } },
      "pipeline:minHighS":       { "@type": "ssn:Property", "name": "Min HIGH Duration","schema:value": { "@value": 0.2, "@type": "xsd:float"   } },
      "pipeline:operatingMode":  { "@type": "ssn:Property", "name": "Operating Mode",  "schema:value": { "@value": "repeat-trigger", "@type": "xsd:string" } },

      "pipeline:sensingPrinciple": { "@value": "Passive infrared — detects differential changes in infrared radiation across two pyroelectric sensing elements.", "@type": "xsd:string" },
      "pipeline:indoorOutdoor":    { "@value": "indoor", "@type": "xsd:string" },

      "sosa:isHostedBy":     "urn:wastebin:bin-01",
      "pipeline:deployedIn": "urn:env:kypes",
      "pipeline:status":     { "@value": "active", "@type": "xsd:string" },
      "pipeline:installedOn":{ "@value": "2026-04-01", "@type": "xsd:date" }
    },

    {
      "@id":   "urn:dev:team08:pir-02",
      "@type": "sosa:Sensor",

      "name":        "HC-SR501 PIR Motion Sensor — Bin 02",
      "description": "HC-SR501 passive infrared motion sensor. Detects motion by sensing differential changes in infrared radiation.",
      "model":       "HC-SR501",

      "sosa:observes": {
        "@type":       "sosa:ObservableProperty",
        "@id":         "urn:prop:team08:motion",
        "name":        "Motion",
        "description": "Instantaneous motion (temperature > ambient) within the sensor field of view."
      },

      "ssn:hasProperty": [
        {
          "@type":              "ssn-system:MeasurementRange",
          "name":               "Detection Range",
          "pipeline:minValueM": { "@value": 0.5, "@type": "xsd:float" },
          "pipeline:maxValueM": { "@value": 7.0, "@type": "xsd:float" }
        },
        {
          "@type":                      "ssn:Property",
          "name":                       "Detection Angle",
          "pipeline:detectionAngleDeg": { "@value": 120, "@type": "xsd:integer" }
        },
        {
          "@type":                "ssn-system:SystemCapability",
          "name":                 "Supply Voltage Range",
          "pipeline:minVoltageV": { "@value": 4.5,  "@type": "xsd:float" },
          "pipeline:maxVoltageV": { "@value": 20.0, "@type": "xsd:float" }
        },
        {
          "@type":                   "ssn-system:SystemCapability",
          "name":                    "Output Signal Voltage HIGH",
          "pipeline:outputVoltageV": { "@value": 3.3, "@type": "xsd:float" }
        }
      ],

      "pipeline:gpioPin":        { "@type": "ssn:Property", "name": "GPIO Pin",        "schema:value": { "@value": 27,  "@type": "xsd:integer" } },
      "pipeline:physicalPin":    { "@type": "ssn:Property", "name": "Physical Pin",    "schema:value": { "@value": 13,  "@type": "xsd:integer" } },
      "pipeline:sampleIntervalS":{ "@type": "ssn:Property", "name": "Sample Interval", "schema:value": { "@value": 0.1, "@type": "xsd:float"   } },
      "pipeline:cooldownS":      { "@type": "ssn:Property", "name": "Cooldown",        "schema:value": { "@value": 5.0, "@type": "xsd:float"   } },
      "pipeline:minHighS":       { "@type": "ssn:Property", "name": "Min HIGH Duration","schema:value": { "@value": 0.2, "@type": "xsd:float"   } },
      "pipeline:operatingMode":  { "@type": "ssn:Property", "name": "Operating Mode",  "schema:value": { "@value": "repeat-trigger", "@type": "xsd:string" } },

      "pipeline:sensingPrinciple": { "@value": "Passive infrared — detects differential changes in infrared radiation across two pyroelectric sensing elements.", "@type": "xsd:string" },
      "pipeline:indoorOutdoor":    { "@value": "indoor", "@type": "xsd:string" },

      "sosa:isHostedBy":     "urn:wastebin:bin-02",
      "pipeline:deployedIn": "urn:env:kypes",
      "pipeline:status":     { "@value": "active", "@type": "xsd:string" },
      "pipeline:installedOn":{ "@value": "2026-04-01", "@type": "xsd:date" }
    }
  ]
}