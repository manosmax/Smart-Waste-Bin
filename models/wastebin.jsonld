{
  "@context": {
    "@vocab":   "https://schema.org/",
    "sosa":     "http://www.w3.org/ns/sosa/",
    "pipeline": "https://github.com/manosmax/Pie/blob/main/docs/ontology.md#",
    "xsd":      "http://www.w3.org/2001/XMLSchema#"
  },

  "@id":   "urn:wastebin:team08:bin-01",
  "@type": "sosa:Platform",

  "name":        "Wastebin 01",
  "description": "General-purpose waste bin deployed in the Kypes lab.",

  "pipeline:material":   "plastic",
  "pipeline:color":      "grey",
  "pipeline:heightCm":   { "@value": "18", "@type": "xsd:integer" },
  "pipeline:diameterCm": { "@value": "8",  "@type": "xsd:integer" },
  "pipeline:capacity":   { "@value": "10", "@type": "xsd:integer" },

  "pipeline:wasteType": "general",
  "pipeline:status":    "active",

  "sosa:hosts": [
    "urn:dev:team08:pir-01"
  ],

  "pipeline:locatedIn": "urn:env:team08:kypes",

  "pipeline:installedOn": { "@value": "2026-04-01", "@type": "xsd:date" }
}
