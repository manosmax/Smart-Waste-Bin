        "id": "85361a868eb34142",
        "type": "function",
        "z": "62019e9d552c6d16",
        "name": "function 2",
        "func": "// ΔΙΟΡΘΩΘΗΚΕ: Το topic πρέπει να ακολουθεί τη δομή της Python για το συγκεκριμένο binary_sensor\nmsg.topic = \"homeassistant/binary_sensor/bin-01_high_alert/config\";\n\nmsg.payload = {\n    \"name\": \"Waste Bin bin-01 High Activity Alert\",\n    \"state_topic\": \"smartbin/bin-01/alerts\",\n    \"value_template\": \"{% if value_json.activity_level == 'high' %}ON{% else %}OFF{% endif %}\",\n    \"device_class\": \"problem\",\n    // ΔΙΟΡΘΩΘΗΚΕ: Το unique_id αλλάχτηκε για να μην μπερδεύεται με το κανονικό motion της Python\n    \"unique_id\": \"bin-01_high_activity_alert\",\n    \"device\": {\n        \"identifiers\": [\"bin-01\"],\n        \"name\": \"Smart Waste Bin bin-01\",\n        \"model\": \"IoT-Bin-v2\",\n        \"manufacturer\": \"Team 08\"\n    }\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
