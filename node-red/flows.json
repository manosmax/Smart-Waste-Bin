    {
        "id": "63e8bf4f36badc27",
        "type": "function",
        "z": "62019e9d552c6d16",
        "name": "function 1",
        "func": "let motionEvents = flow.get(\"motion_events\") || [];\n\nconst currentTime = Date.now();\n\nconst windowSizeMinutes = 10;\nconst timeWindowMs = windowSizeMinutes * 60 * 1000;\nmotionEvents.push(currentTime);\n\nmotionEvents = motionEvents.filter(eventTime => {\n    return (currentTime - eventTime) < timeWindowMs;\n});\n\nflow.set(\"motion_events\", motionEvents);\n\nconst eventCount = motionEvents.length;\n\nlet activityLevel = \"idle\";\nif (eventCount === 0) {\n    activityLevel = \"idle\";\n} else if (eventCount <= 4) {\n    activityLevel = \"low\";\n} else if (eventCount <= 7) {\n    activityLevel = \"medium\";\n} else {\n    activityLevel = \"high\";\n}\nmsg.payload = {\n    activity_level: activityLevel,\n    event_count: eventCount,\n    window_size_minutes: windowSizeMinutes,\n    evaluation_timestamp: new Date(currentTime).toISOString()\n};\n\nmsg.payload = eventCount;  // gauge reads this number directly\nreturn msg;\n\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 300,
        "y": 780,
        "wires": [
